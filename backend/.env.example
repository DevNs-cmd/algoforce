# Server Configuration
PORT=8080
NODE_ENV=production

# MongoDB Configuration
MONGO_URI=mongodb+srv://your_username:your_password@cluster.mongodb.net/algoforce?retryWrites=true&w=majority

# Twilio Configuration (Required for SMS OTP)
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_SERVICE_SID=your_service_sid_here

# JWT Authentication Secret (change this in production!)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Google OAuth
GOOGLE_CLIENT_ID=your_google_oauth_client_id

# AI Provider API Keys (add the providers you want to use)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
OPENROUTER_API_KEY=sk-or-...

# Ollama (only needed if running local Ollama models)
OLLAMA_BASE_URL=http://localhost:11434/v1
